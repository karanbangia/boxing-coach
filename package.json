{
  "name": "boxing-coach",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "core:build": "pnpm --filter @boxing-coach/core build",
    "web": "pnpm --filter @boxing-coach/web dev",
    "web:build": "pnpm --filter @boxing-coach/web build",
    "web:preview": "pnpm --filter @boxing-coach/web preview",
    "mobile": "pnpm --filter @boxing-coach/mobile start",
    "mobile:build": "pnpm --filter @boxing-coach/mobile build",
    "ios": "pnpm --filter @boxing-coach/mobile ios",
    "android": "pnpm --filter @boxing-coach/mobile android",
    "android:build:preview": "pnpm --filter @boxing-coach/mobile eas:build:android:preview",
    "android:build:production": "pnpm --filter @boxing-coach/mobile eas:build:android:production",
    "android:submit": "pnpm --filter @boxing-coach/mobile eas:submit:android",
    "ios:build:simulator": "pnpm --filter @boxing-coach/mobile eas:build:ios:simulator",
    "ios:build:production": "pnpm --filter @boxing-coach/mobile eas:build:ios:production",
    "ios:submit": "pnpm --filter @boxing-coach/mobile eas:submit:ios"
  },
  "devDependencies": {
    "turbo": " ^2"
  }
}

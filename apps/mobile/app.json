{
  "expo": {
    "name": "Boxing Coach",
    "slug": "boxing-coach-mobile",
    "version": "1.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karanbangia.boxingcoach",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.karanbangia.boxingcoach",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Boxing Coach to choose your fighter profile photo.",
          "cameraPermission": "Allow Boxing Coach to capture your fighter profile photo."
        }
      ]
    ],
    "autolinking": {
      "ios": {
        "buildFromSource": [
          "react-native-reanimated",
          "react-native-worklets"
        ]
      }
    },
    "scheme": "boxingcoach",
    "extra": {
      "eas": {
        "projectId": "38b1da3f-b65c-42e6-95d9-9f321c7e7fb8"
      }
    }
  }
}

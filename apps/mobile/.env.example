EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# New Firebase projects require a billing-enabled Cloud Storage bucket for uploads.
# Keep this false until Storage is enabled and its rules have been deployed.
EXPO_PUBLIC_FIREBASE_PROFILE_PHOTO_UPLOADS_ENABLED=false

# OAuth client IDs from the same Firebase/Google Cloud project.
EXPO_PUBLIC_FIREBASE_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_FIREBASE_GOOGLE_IOS_CLIENT_ID=

# Reversed iOS client ID, for example com.googleusercontent.apps.123-abc.
# This is consumed while Expo creates the native iOS build.
EXPO_PUBLIC_FIREBASE_GOOGLE_IOS_URL_SCHEME=
